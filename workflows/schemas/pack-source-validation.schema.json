{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yersonargotev/packy/workflows/schemas/pack-source-validation.schema.json",
  "title": "Pack source sandbox validation proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "plan_id",
    "base_sha",
    "candidate_sha",
    "packy_suite",
    "apply",
    "contains_upstream_bytes"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "source_id": { "type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$" },
    "plan_id": { "type": "string", "minLength": 1 },
    "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "candidate_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "packy_suite": { "const": true },
    "apply": { "const": true },
    "contains_upstream_bytes": { "const": false }
  }
}
