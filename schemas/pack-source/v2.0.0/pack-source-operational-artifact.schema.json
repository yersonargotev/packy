{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yersonargotev.github.io/packy/schemas/pack-source/v2.0.0/pack-source-operational-artifact.schema.json",
  "title": "Pack source synchronization operational artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "state",
    "source_id",
    "blockers",
    "recovery",
    "contains_secrets",
    "contains_upstream_bytes"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "state": { "const": "blocked" },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$"
    },
    "plan_id": { "type": "string", "minLength": 1 },
    "base_sha": { "$ref": "#/$defs/full_sha" },
    "candidate_sha": { "$ref": "#/$defs/full_sha" },
    "source_lock_sha256": { "$ref": "#/$defs/sha256" },
    "lock_set_sha256": { "$ref": "#/$defs/sha256" },
    "config_sha256": { "$ref": "#/$defs/sha256" },
    "manifests_sha256": { "$ref": "#/$defs/sha256" },
    "blockers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "recovery": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "run_url": { "type": "string", "format": "uri" },
    "contains_secrets": { "const": false },
    "contains_upstream_bytes": { "const": false }
  },
  "allOf": [
    {
      "if": { "required": ["plan_id"] },
      "then": {
        "required": [
          "source_lock_sha256",
          "lock_set_sha256",
          "config_sha256",
          "manifests_sha256"
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            { "required": ["source_lock_sha256"] },
            { "required": ["lock_set_sha256"] },
            { "required": ["config_sha256"] },
            { "required": ["manifests_sha256"] }
          ]
        }
      }
    }
  ],
  "$defs": {
    "full_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
